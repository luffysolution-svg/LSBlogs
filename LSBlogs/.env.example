# Public configuration bundled into the browser. This is not a secret.
NEXT_PUBLIC_GITHUB_COMMENTS_REPO=your-github-name/your-comments-repo
NEXT_PUBLIC_GITHUB_COMMENTS_LABEL=blog-comment

# Optional server-only integrations. Never commit real values.
GEMINI_API_KEY=
QWEATHER_KEY=

# Online CMS. All values below are server-only.
# Generate/update the first two values with: npm run cms:password
# Use a fine-grained GitHub token limited to this repository with
# Contents: write and Pull requests: write permissions.
CMS_ADMIN_PASSWORD=
CMS_SESSION_SECRET=
CMS_GITHUB_REPO=your-github-name/your-blog-repo
CMS_GITHUB_BRANCH=main
# The template repository keeps the Next.js app in LSBlogs/. If your app is
# at the repository root, leave this empty.
CMS_GITHUB_ROOT=LSBlogs

# Connect one public Vercel Blob store. Public images are stored as normal
# blobs; CMS state is AES-256-GCM encrypted before upload.
BLOB_READ_WRITE_TOKEN=
